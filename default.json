{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:js-lib",
        ":automergeBranch",
        ":automergeMinor",
        ":dependencyDashboard",
        ":label(renovate)",
        ":prNotPending",
        ":rebaseStalePrs",
        "replacements:all"
    ],
    "timezone": "Europe/Stockholm",
    "semanticCommits": "enabled",
    "automergeSchedule": ["* 0-7,19-23 * * 1-5", "* * * * 0,6"],

    "major": {
        "automergeType": "pr"
    },
    "ignoreDeps": ["vue-styleguidist", "vue-cli-plugin-styleguidist"],
    "ignorePaths": ["**/.mvn/wrapper/maven-wrapper.properties"],
    "minimumReleaseAge": "3 days",
    "lockFileMaintenance": { "enabled": true },
    "packageRules": [
        {
            "matchManagers": ["docker", "dockerfile"],
            "enabled": false
        },
        {
            "matchManagers": ["gradle", "maven"],
            "matchPackageNames": ["!se.fk{/,}**"]
        },

        {
            "description": "Merge these packages at any time (even during office-hours)",
            "matchPackageNames": ["@forsakringskassan/**", "@fkui/**"],
            "automergeSchedule": ["* * * * *"]
        },

        {
            "matchDepTypes": ["dependencies", "peerDependencies"],
            "semanticCommitType": "fix"
        },

        {
            "matchDepTypes": ["dependencies", "peerDependencies"],
            "matchUpdateTypes": ["major"],
            "semanticCommitType": "feat"
        },

        {
            "matchDepTypes": ["peerDependencies"],
            "matchUpdateTypes": ["major"],
            "semanticCommitType": "feat",
            "commitMessageTopic": "support {{depName}} v{{newMajor}}"
        },

        {
            "description": "Group all @forsakringskassan/eslint packages together",
            "matchSourceUrls": [
                "https://github.com/forsakringskassan/eslint-config"
            ],
            "groupName": "@forsakringskassan/eslint-config monorepo",
            "groupSlug": "eslint-config-monorepo",
            "minimumReleaseAge": null
        },

        {
            "description": "Group all @forsakringskassan/jest-config packages together",
            "matchSourceUrls": [
                "https://github.com/forsakringskassan/jest-config"
            ],
            "groupName": "@forsakringskassan/jest-config monorepo",
            "groupSlug": "jest-config-monorepo",
            "minimumReleaseAge": null
        },

        {
            "description": "Group all @forsakringskassan/prettier packages together",
            "matchSourceUrls": [
                "https://github.com/forsakringskassan/prettier-config"
            ],
            "groupName": "@forsakringskassan/prettier-config monorepo",
            "groupSlug": "prettier-config-monorepo",
            "minimumReleaseAge": null
        },

        {
            "description": "Group all @fkui/* packages together",
            "matchPackageNames": ["@fkui/**"],
            "groupSlug": "fkui",
            "groupName": "@fkui packages",
            "separateMultipleMajor": true,
            "minimumReleaseAge": null
        },

        {
            "description": "Internal packages",
            "matchPackageNames": ["@forsakringskassan/**"],
            "minimumReleaseAge": null
        },

        {
            "description": "Group all html-validate packages together",
            "matchPackageNames": [
                "@html-validate/**",
                "html-validate",
                "/^html-validate-/",
                "/-html-validate$/",
                "!@html-validate/release-scripts"
            ],
            "groupName": "html-validate",
            "minimumReleaseAge": null
        },

        {
            "description": "No minimum release age for lockfile maintenance",
            "matchUpdateTypes": ["lockFileMaintenance"],
            "minimumReleaseAge": null
        },

        {
            "description": "Add `@forsakringskassan/jest-config` `major` update to Jest monorepo.",
            "matchSourceUrls": [
                "https://github.com/Forsakringskassan/jest-config.git"
            ],
            "matchUpdateTypes": ["major"],
            "groupName": "jest monorepo"
        },

        {
            "description": "Update each minor version of typescript separately",
            "matchPackageNames": ["typescript"],
            "separateMinorPatch": true
        }
    ]
}
